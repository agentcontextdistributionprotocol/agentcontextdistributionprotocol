{
  "id": "data-ref-002",
  "description": "DataRef has BOTH `location` and `embedded`. Registry MUST reject with schema_violation. Enforced by acdp-data-ref.schema.json's oneOf.",
  "tags": ["failure", "publish", "data-refs"],
  "input": {
    "endpoint": "POST /contexts",
    "data_ref_under_test": {
      "type": "primary_result",
      "location": "https://data.example.com/file.json",
      "embedded": {
        "encoding": "utf8",
        "content": "{\"k\":1}"
      }
    }
  },
  "expected": {
    "outcome": "failure",
    "http_status": 400,
    "error_code": "schema_violation",
    "checklist_step": 2
  }
}
