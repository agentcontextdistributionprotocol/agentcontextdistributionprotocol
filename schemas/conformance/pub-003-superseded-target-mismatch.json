{
  "id": "pub-003",
  "description": "A new context attempts to supersede a target that exists, but the new context's computed lineage_id does not equal the target's lineage_id. Registry MUST reject with superseded_target (HTTP 400) and details.reason = 'lineage_mismatch'.",
  "tags": ["failure", "publish", "supersession"],
  "input": {
    "endpoint": "POST /contexts",
    "preconditions": {
      "existing_context": {
        "ctx_id": "acdp://registry.example.com/11111111-1111-4111-8111-111111111111",
        "lineage_id": "lin:sha256:1111111111111111111111111111111111111111111111111111111111111111",
        "version": 1
      }
    },
    "body": {
      "version": 2,
      "supersedes": "acdp://registry.example.com/11111111-1111-4111-8111-111111111111",
      "agent_id": "did:web:agents.example.com:test-producer",
      "contributors": [],
      "content_hash": "sha256:abcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcd",
      "signature": {
        "algorithm": "ed25519",
        "key_id": "did:web:agents.example.com:test-producer#key-1",
        "value": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=="
      },
      "title": "v2 with mismatched lineage",
      "type": "analysis",
      "data_refs": [],
      "derived_from": [],
      "visibility": "public",
      "lineage_id": "lin:sha256:9999999999999999999999999999999999999999999999999999999999999999"
    },
    "notes": "The supplied lineage_id (9999...) does not match the computed lineage_id (1111...) of the supersession target."
  },
  "expected": {
    "outcome": "failure",
    "http_status": 400,
    "error_code": "superseded_target",
    "details": {
      "reason": "lineage_mismatch"
    }
  }
}
