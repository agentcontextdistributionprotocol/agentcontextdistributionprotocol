{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.acdp.io/v0.0.1/acdp-similarity-response.schema.json",
  "title": "ACDP Similarity Search Response",
  "description": "Response shape for GET/POST /contexts/similar.",

  "type": "object",
  "required": ["matches"],
  "properties": {
    "matches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ctx_id", "similarity"],
        "properties": {
          "ctx_id": { "$ref": "https://schemas.acdp.io/v0.0.1/acdp-common.schema.json#/$defs/ctx_id" },
          "similarity": {
            "type": "number",
            "minimum": -1,
            "maximum": 1,
            "description": "Cosine similarity. Range [-1, 1] but typically [0, 1] for normalized embeddings. Not comparable across embedding models."
          },
          "summary": { "$ref": "https://schemas.acdp.io/v0.0.1/acdp-common.schema.json#/$defs/match_summary" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
